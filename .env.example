# =============================================================================
# GitHub Configuration
# =============================================================================
# Your GitHub Personal Access Token (fine-grained, repo-scoped)
# Needs: pull_requests (read/write), contents (read), issues (write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Secret you set when registering the webhook on GitHub
# Used to validate incoming webhook payloads via HMAC-SHA256
GITHUB_WEBHOOK_SECRET=your_random_secret_string

# Optional: GitHub App credentials (for v2 multi-repo support)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem

# =============================================================================
# LLM Provider — Groq (free tier, fast)
# =============================================================================
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Set LLM_PROVIDER=groq below to use Groq

# =============================================================================
# LLM Provider — xAI Grok (optional)
# =============================================================================
# GROK_API_KEY=...
# GROK_MODEL=grok-2-latest
# GROK_BASE_URL=https://api.x.ai/v1

# =============================================================================
# LLM Provider — Ollama (free, local)
# =============================================================================
# Ollama model name (pull it first: ollama pull deepseek-coder)
OLLAMA_MODEL=deepseek-coder
# Ollama API base URL (localhost only — bind to 127.0.0.1)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# LLM Provider — Anthropic (optional, pay-per-use, better quality)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/code_review_agent

# Individual parts (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=code_review_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# Redis (Celery broker + caching)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# =============================================================================
# ChromaDB (Vector store for RAG)
# =============================================================================
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=codebase_patterns

# =============================================================================
# Embeddings (RAG)
# =============================================================================
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Application
# =============================================================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your_random_secret_here
LOG_LEVEL=INFO

# =============================================================================
# Celery Worker
# =============================================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIMEOUT=300

# =============================================================================
# MCP Server
# =============================================================================
MCP_SERVER_PORT=9000
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-coder

# =============================================================================
# Security & Limits
# =============================================================================
MAX_FILES_TO_REVIEW=20
MAX_COMMENTS_PER_REVIEW=15
REVIEW_TIMEOUT_SECONDS=300
EXCLUDE_PATTERNS=*.lock,*.exe,*.dll,*.so,*.bin,node_modules/,dist/,build/,vendor/,__pycache__/
RATE_LIMIT_WEBHOOKS_PER_MINUTE=30
